# Local-only GoMode configuration.
# Copy to `.env` if your local launcher reads dotenv files, or pass the public
# Flutter values with `--dart-define`. Never commit `.env`.

# Public Flutter runtime configuration. No Google Maps server key belongs here.
GOMODE_FIREBASE_ENABLED=false
GOMODE_FIREBASE_FUNCTIONS_REGION=us-central1
GOMODE_FIREBASE_API_KEY=
GOMODE_FIREBASE_APP_ID=
GOMODE_FIREBASE_MESSAGING_SENDER_ID=
GOMODE_FIREBASE_PROJECT_ID=wingman-interactive-live
GOMODE_FIREBASE_AUTH_DOMAIN=
GOMODE_FIREBASE_STORAGE_BUCKET=
GOMODE_FIREBASE_MEASUREMENT_ID=
GOMODE_FUNCTIONS_EMULATOR_HOST=
GOMODE_FUNCTIONS_EMULATOR_PORT=5001
GOMODE_RECAPTCHA_SITE_KEY=
GOMODE_MAPS_WIDGET_ENABLED=false

# Native mobile map display keys are supplied through restricted platform build
# settings, not Dart defines: GOMODE_GOOGLE_MAPS_ANDROID_SDK_KEY (Gradle
# property) and GOMODE_GOOGLE_MAPS_IOS_SDK_KEY (Xcode build setting).

# Development-only REST proxy override. Production uses Firebase callable
# functions with App Check; leave this empty for normal builds.
GOMODE_BACKEND_BASE_URL=

# Non-secret backend parameters (set through Firebase parameter configuration).
ENABLE_SOLAR_API=false
ENABLE_AIR_QUALITY_FORECAST=false

# Backend secret names are documented here intentionally without values.
# Set them with Firebase Secret Manager commands, never in `.env`:
# GOMODE_GOOGLE_MAPS_API_KEY
# GOMODE_PHOTO_PROXY_SIGNING_KEY
